    "db:seed": "prisma db seed",
    "worker:publishing": "tsx src/workers/publishing-worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.797.0",
    "@aws-sdk/s3-request-presigner": "^3.797.0",
    "@prisma/client": "^6.14.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.43.1",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.5.2",
    "ioredis": "^5.6.1",
    "jose": "^5.9.6",
    "lucide-react": "^1.21.0",
    "next": "^15.5.2",
    "postcss": "^8.5.15",
    "prisma": "^6.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
