generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  PRODUCER
  HOST
  EDITOR
  DJ_STREAMER
  SPONSOR_MANAGER
  ANALYTICS_VIEWER
}

enum PublishingState {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
  FAILED
}

enum ContentType {
  EPISODE
  CLIP
  SHOW
  BLOG_POST
  SPONSOR_SPOT
  PLAYLIST_BLOCK
}

enum JobType {
  NORMALIZE_AUDIO
  GENERATE_WAVEFORM
  GENERATE_TRANSCRIPT
  EXTRACT_CLIPS
  GENERATE_THUMBNAIL
  REGENERATE_RSS
  PUBLISH_YOUTUBE
  PULL_ANALYTICS
  SYNC_AZURACAST
}

enum JobState {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  RETRYING
}

enum ScheduleLabel {
  LIVE
  UPCOMING
  REPLAY
  AUTODJ
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(EDITOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Host {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  bio       String
  socials   Json      @default("{}")
  contact   String?
  shows     Show[]    @relation("HostShows")
  episodes  Episode[] @relation("EpisodeHosts")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Show {
  id                 String          @id @default(cuid())
  title              String
  slug               String          @unique
  description        String
  coverArtUrl        String
  tags               String[]
  preferredPlatforms String[]
  state              PublishingState @default(PUBLISHED)
  hosts              Host[]          @relation("HostShows")
  episodes           Episode[]
  clips              Clip[]
  scheduleBlocks     ScheduleBlock[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Episode {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  summary       String
  publishDate   DateTime
  duration      String
  state         PublishingState @default(DRAFT)
  audioUrl      String?
  videoUrl      String?
  artworkUrl    String?
  transcript    String?
  chapters      Json           @default("[]")
  platformLinks Json           @default("{}")
  showId        String
  show          Show            @relation(fields: [showId], references: [id], onDelete: Cascade)
  hosts         Host[]          @relation("EpisodeHosts")
  clips         Clip[]
  mediaAssets   MediaAsset[]
  publishingJobs PublishingJob[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Clip {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  caption       String
  state         PublishingState @default(DRAFT)
  videoUrl      String?
  thumbnailUrl  String?
  episodeId     String?
  episode       Episode?        @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  showId        String?
  show          Show?           @relation(fields: [showId], references: [id], onDelete: SetNull)
  publishingJobs PublishingJob[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model BlogPost {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  excerpt     String
  body        String
  state       PublishingState @default(DRAFT)
  authorName  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Guest {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  bio       String
  socials   Json     @default("{}")
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  notes     String
  state     PublishingState @default(DRAFT)
  spotUrl   String?
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Playlist {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  category    String
  priority    Int             @default(0)
  state       PublishingState @default(DRAFT)
  azuracastId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ScheduleBlock {
  id          String        @id @default(cuid())
  title       String
  startsAt    DateTime
  endsAt      DateTime
  timezone    String        @default("Australia/Brisbane")
  recurrence  String?
  label       ScheduleLabel @default(UPCOMING)
  playlist    String?
  showId      String?
  show        Show?         @relation(fields: [showId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  key          String   @unique
  bucket       String
  url          String
  mimeType     String
  sizeBytes    BigInt
  purpose      String
  episodeId    String?
  episode      Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model PublishingJob {
  id          String     @id @default(cuid())
  type        JobType
  state       JobState   @default(QUEUED)
  attempts    Int        @default(0)
  payload     Json       @default("{}")
  lastError   String?
  nextRunAt   DateTime?
  episodeId   String?
  episode     Episode?   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  clipId      String?
  clip        Clip?      @relation(fields: [clipId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AnalyticsSnapshot {
  id             String   @id @default(cuid())
  liveListeners  Int      @default(0)
  concurrentPeak Int      @default(0)
  avgSessionSec  Int      @default(0)
  episodePlays   Int      @default(0)
  podcastDownloads Int    @default(0)
  videoWatchSec  Int      @default(0)
  topClips       Json     @default("[]")
  referrals      Json     @default("{}")
  capturedAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
}
